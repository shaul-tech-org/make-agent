      },
      "frontmatterFields": ["name", "description"],
      "notes": "Cursor는 agents, rules 미지원 — skills만 변환, 프론트매터 최소화"
    },
    "gemini": {
      "configDir": ".gemini",
      "displayName": "Gemini CLI",
      "placeholders": {
        "model": "Gemini",
        "config_file": "GEMINI.md",
        "command_prefix": "/",
        "ask_instruction": "ask the user directly to clarify."
      },
      "frontmatterFields": ["name", "description"],
      "notes": "Gemini는 skills 디렉토리 지원, agents/rules 미지원"
    }
  },
  "sourceDir": ".claude",
  "distDir": "dist",
  "version": "1.0.0"
