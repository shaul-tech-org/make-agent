{
  "providers": {
    "claude-code": {
      "configDir": ".claude",
      "displayName": "Claude Code",
      "placeholders": {
        "model": "Claude",
        "config_file": "CLAUDE.md",
        "command_prefix": "/",
        "ask_instruction": "STOP and call the AskUserQuestion tool to clarify."
      },
      "frontmatterFields": ["user-invocable", "argument-hint", "name", "description"]
    },
    "cursor": {
      "configDir": ".cursor",
      "displayName": "Cursor",
      "placeholders": {
        "model": "the model",
        "config_file": ".cursorrules",
